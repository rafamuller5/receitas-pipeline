{
    "name": "gcs/sistema-receitas",
    "description": "Sistema de Receitas — GCS 2026/A",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "includes/conexao.php",
            "includes/auth.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "test-coverage": "phpunit --configuration phpunit.xml --coverage-text",
        "cs-check": "phpcs --standard=PSR12 --extensions=php . --ignore=vendor,tests",
        "cs-fix": "phpcbf --standard=PSR12 --extensions=php . --ignore=vendor,tests"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
